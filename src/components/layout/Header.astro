---
import Button from '../ui/Button.astro';
import logoIconRaw from '../../assets/logo-icon.svg?raw';
import logoTextRaw from '../../assets/Logo-text.svg?raw';

const logoIcon = logoIconRaw.replace('<svg ', '<svg style="height: 28px; width: auto; display: block;" ');
const logoText = logoTextRaw
  .replace(/fill="white"/g, 'fill="#6D57BD"')
  .replace('<svg ', '<svg style="height: 19px; width: auto; display: block;" ');

const navLinks = [
  { href: '/', label: 'Hjem' },
  { href: '/om-os', label: 'Om os' },
  { href: '/kontakt', label: 'Kontakt' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-dark/8"
  id="site-header"
>
  <div class="max-w-6xl mx-auto px-6">
    <div class="relative flex items-center justify-between h-16 md:h-18">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 text-dark" aria-label="HelloWeb forside">
        <span set:html={logoIcon} />
        <span class="hidden sm:block" set:html={logoText} />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex absolute left-1/2 -translate-x-1/2 items-center gap-8" aria-label="Primær navigation">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class={`relative font-body text-sm font-bold transition-colors duration-150 pb-0.5
              after:absolute after:bottom-0 after:left-0 after:h-[2px] after:w-full after:rounded-full after:bg-primary after:transition-transform after:duration-200 after:origin-left
              ${currentPath === href
                ? 'text-primary after:scale-x-100'
                : 'text-dark/60 hover:text-dark after:scale-x-0 hover:after:scale-x-100'
              }`}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden md:block">
        <Button href="/kontakt" size="sm">
          Få en uforpligtende snak
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </Button>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 -mr-2 text-dark/70 hover:text-dark transition-colors"
        aria-label="Åbn menu"
        aria-expanded="false"
      >
        <svg id="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="17" x2="21" y2="17"/></svg>
        <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>

    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white/95 backdrop-blur-md border-t border-dark/8">
    <nav class="max-w-6xl mx-auto px-6 py-5 flex flex-col gap-4">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`font-body text-base font-bold transition-colors ${
            currentPath === href ? 'text-primary ' : 'text-dark/70'
          }`}
        >
          {label}
        </a>
      ))}
      <div class="pt-2">
        <Button href="/kontakt" size="sm" class="w-full justify-center">
          Få en gratis gennemgang
        </Button>
      </div>
    </nav>
  </div>
</header>

<div class="h-16 md:h-18"></div>

<script>
  const header = document.getElementById('site-header')!;
  const toggle = document.getElementById('mobile-menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconMenu = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden');
    iconMenu.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
