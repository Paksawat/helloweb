---
import Button from '../ui/Button.astro';
import SectionLabel from '../ui/SectionLabel.astro';
---

<section class="relative overflow-hidden bg-dark grid-pattern">

  <div class="max-w-6xl mx-auto px-6 py-20 md:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-[1.15fr_0.85fr] gap-16 items-center">

      <!-- Text column -->
      <div>
        <SectionLabel text="Din digitale tilstedeværelse" light />

        <h1 class="font-display font-extrabold text-[2.8rem] sm:text-[3.5rem] md:text-[4.25rem] leading-[1.05] tracking-[-0.02em] text-white mb-6">
          Vi bygger og vedligeholder din<br /><span class="text-accent">digital fremtid</span>
        </h1>

        <p class="text-lg md:text-xl text-white/60 leading-relaxed max-w-xl mb-10">
          Skabe henvendelser uden at du skal bruge tid på teknikken. Vi tilbyder professionelle samarbejder til små virksomheder. <br>
          <span class="text-white/80">Du for en fagperson med +10 års erfaring.</span>
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-8">
          <Button href="/kontakt" size="lg">
            Få en uforpligtende snak
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </Button>
        </div>

      </div>

      <!-- Visual column -->
      <div class="relative hidden lg:block">
        <!-- Browser mockup -->
        <div class="relative rotate-1 shadow-primary-lg rounded-2xl overflow-hidden border border-white/10">
          <div class="bg-slate-800 border-b border-white/10 px-4 py-3 flex items-center gap-3">
            <div class="flex gap-1.5" aria-hidden="true">
              <span class="w-3 h-3 rounded-full bg-red-400/80"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-400/80"></span>
              <span class="w-3 h-3 rounded-full bg-green-400/80"></span>
            </div>
            <div class="flex-1 bg-white/20 rounded-full px-4 py-1.5 text-xs text-white/40 border border-white/10 font-body">
              din-virksomhed.dk
            </div>
          </div>

          <div class="bg-white p-5 space-y-4">
            <div class="flex items-center justify-between py-1">
              <div class="h-3 w-16 bg-dark/15 rounded-full"></div>
              <div class="flex items-center gap-3">
                <div class="h-2 w-8 bg-dark/10 rounded-full"></div>
                <div class="h-2 w-8 bg-dark/10 rounded-full"></div>
                <div class="h-7 w-20 rounded-full bg-primary"></div>
              </div>
            </div>

            <div class="bg-gray-50 rounded-xl p-5 space-y-3">
              <div class="h-5 w-4/5 bg-dark/15 rounded-full"></div>
              <div class="h-5 w-3/5 bg-dark/15 rounded-full"></div>
              <div class="h-3 w-full bg-dark/8 rounded-full mt-2"></div>
              <div class="h-3 w-5/6 bg-dark/8 rounded-full"></div>
              <div class="h-9 w-36 rounded-full bg-primary mt-3"></div>
            </div>

            <div class="grid grid-cols-3 gap-2.5">
              {[0, 1, 2].map(() => (
                <div class="bg-gray-50 rounded-xl p-3 space-y-2.5">
                  <div class="h-7 w-7 rounded-lg bg-primary/80"></div>
                  <div class="h-2 w-full bg-dark/12 rounded-full"></div>
                  <div class="h-2 w-3/4 bg-dark/8 rounded-full"></div>
                  <div class="h-2 w-2/3 bg-dark/6 rounded-full"></div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Floating trust badge -->
        <div class="absolute -bottom-5 -left-6 bg-white rounded-2xl shadow-card border border-dark/8 px-4 py-3 flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-primary flex items-center justify-center flex-shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <p class="text-xs font-semibold text-dark leading-tight">Klar til at gå live</p>
            <p class="text-xs text-dark/45 leading-tight">Din nye hjemmeside</p>
          </div>
        </div>

        <!-- Floating update badge -->
        <div class="absolute -top-4 -right-4 bg-white rounded-xl shadow-lg px-3 py-2.5 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent animate-pulse flex-shrink-0"></span>
          <p class="text-xs font-medium text-darkleading-tight font-mono">Opdatering live</p>
        </div>
      </div>

    </div>
  </div>
</section>
