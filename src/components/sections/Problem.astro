---
import SectionLabel from '../ui/SectionLabel.astro';
---

<section class="section-padding bg-dark relative overflow-hidden grid-pattern">

  <div class="container-tight relative">

    <!-- Header + text -->
    <div class="text-center mb-14 animate-on-scroll">
      <SectionLabel text="Problemet" light />
      <h2 class="font-display text-4xl md:text-5xl text-white leading-[1.1] max-w-3xl mx-auto mb-7">
        De fleste hjemmesider skaber ikke  <span class="text-accent">den tillid, de burde</span>
      </h2>
      <p class="text-white/55 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto">
        Mange virksomheder har en hjemmeside, men den bliver sjældent opdateret, ser ikke professionel ud eller giver nogen henvendelser. Resultatet er, at potentielle kunder vælger en konkurrent i stedet.
      </p>
    </div>

    <!-- Stat cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-14 animate-on-scroll delay-2">
      <div class="bg-white/5 border border-white/10 rounded-3xl p-8 text-center">
        <p class="font-display font-extrabold text-5xl md:text-6xl text-white mb-3 leading-none">
          75<span class="text-accent">%</span>
        </p>
        <p class="text-white/50 text-sm leading-relaxed">
          Af brugere vurderer virksomheders troværdighed ud fra hjemmesidens design
        </p>
      </div>
      <div class="bg-white/5 border border-white/10 rounded-3xl p-8 text-center">
        <p class="font-display font-extrabold text-5xl md:text-6xl text-white mb-3 leading-none">
          3<span class="text-accent text-3xl font-bold"> sek</span>
        </p>
        <p class="text-white/50 text-sm leading-relaxed">
          Så lang tid har du til at skabe et godt første indtryk – inden kunden er væk
        </p>
      </div>
      <div class="bg-white/5 border border-white/10 rounded-3xl p-8 text-center">
        <p class="font-display font-extrabold text-5xl md:text-6xl text-white mb-3 leading-none">
          38<span class="text-accent">%</span>
        </p>
        <p class="text-white/50 text-sm leading-relaxed">
          Forlader en hjemmeside hvis layoutet er uattraktivt eller indholdet virker rodet
        </p>
      </div>
    </div>

    <!-- Customer journey flow -->
    <div class="animate-on-scroll delay-3">
      <div class="flex flex-col sm:flex-row items-stretch justify-center gap-3">

        <!-- Step 1 -->
        <div class="flex-1 max-w-[180px] mx-auto sm:mx-0 bg-white/5 border border-white/10 rounded-2xl px-5 py-5 text-center flex flex-col items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/70"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          </div>
          <p class="text-white text-xs font-medium leading-snug">Potentiel kunde søger online</p>
        </div>

        <!-- Arrow -->
        <div class="flex items-center justify-center sm:px-1 text-white/20 rotate-90 sm:rotate-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>

        <!-- Step 2 -->
        <div class="flex-1 max-w-[180px] mx-auto sm:mx-0 bg-red-500/10 border border-red-500/20 rounded-2xl px-5 py-5 text-center flex flex-col items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-red-500/20 flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-400"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <div>
            <p class="text-white text-xs font-medium leading-snug">Finder din hjemmeside</p>
            <p class="text-red-400/80 text-[11px] mt-1">Forældet & uprofessionel</p>
          </div>
        </div>

        <!-- Arrow -->
        <div class="flex items-center justify-center sm:px-1 text-white/20 rotate-90 sm:rotate-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>

        <!-- Step 3 -->
        <div class="flex-1 max-w-[180px] mx-auto sm:mx-0 bg-red-500/10 border border-red-500/20 rounded-2xl px-5 py-5 text-center flex flex-col items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-red-500/20 flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-400"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          </div>
          <div>
            <p class="text-white text-xs font-medium leading-snug">Forlader siden</p>
            <p class="text-red-400/80 text-[11px] mt-1">Under 3 sekunder</p>
          </div>
        </div>

        <!-- Arrow -->
        <div class="flex items-center justify-center sm:px-1 text-white/20 rotate-90 sm:rotate-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>

        <!-- Step 4 -->
        <div class="flex-1 max-w-[180px] mx-auto sm:mx-0 bg-accent/10 border border-accent/20 rounded-2xl px-5 py-5 text-center flex flex-col items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <p class="text-white text-xs font-medium leading-snug">Vælger konkurrenten</p>
            <p class="text-accent/80 text-[11px] mt-1">Du mister kunden</p>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>
