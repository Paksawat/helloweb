---
import SectionLabel from '../ui/SectionLabel.astro';
import showcase1 from '../../assets/showcase-1.webp';
import showcase2 from '../../assets/showcase-2.webp';
import { Image } from 'astro:assets';

const projects = [
  {
    image: showcase1,
    alt: 'Massøer hjemmeside',
    title: 'Massøer',
    url: 'massoer-showcase.vercel.app',
    href: 'https://massoer-showcase.vercel.app/',
    tag: 'Massageterapeut',
  },
  {
    image: showcase2,
    alt: 'Tømrer hjemmeside',
    title: 'Tømrer',
    url: 'tomrer-showcase.vercel.app',
    href: 'https://tomrer-showcase.vercel.app/',
    tag: 'Håndværker',
  },
];
---

<section class="section-padding bg-dark relative overflow-hidden grid-pattern">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] bg-primary/10 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>

  <div class="container-tight relative">
    <div class="text-center mb-16 animate-on-scroll">
      <SectionLabel text="Vores arbejde" light />
      <h2 class="font-display text-4xl md:text-5xl text-white leading-[1.1]">
        Se hvad vi <span class="text-accent">har bygget</span>
      </h2>
      <p class="mt-4 text-white/45 text-lg max-w-lg mx-auto leading-relaxed">
        Eksempler på hjemmesider vi har designet og bygget.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-10">
      {projects.map((project, i) => (
        <a
          href={project.href}
          target="_blank"
          rel="noopener noreferrer"
          class={`animate-on-scroll delay-${i + 1} group block`}
        >
          <!-- Browser mockup -->
          <div class="rounded-2xl overflow-hidden border border-white/10 group-hover:border-accent/30 transition-colors duration-300">
            <!-- Chrome bar -->
            <div class="bg-slate-800 border-b border-white/10 px-4 py-3 flex items-center gap-3">
              <div class="flex gap-1.5 flex-shrink-0" aria-hidden="true">
                <span class="w-2.5 h-2.5 rounded-full bg-red-400/70"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-yellow-400/70"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-green-400/70"></span>
              </div>
              <div class="flex-1 bg-white/10 rounded-full px-3 py-1 text-xs text-white/35 border border-white/10 font-body truncate">
                {project.url}
              </div>
            </div>

            <!-- Screenshot -->
            <div class="relative overflow-hidden aspect-[16/10]">
              <Image
                src={project.image}
                alt={project.alt}
                class="w-full h-full object-cover object-top group-hover:scale-[1.03] transition-transform duration-700 ease-out"
              />
              <div class="absolute inset-0 bg-dark/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-5 py-2.5 flex items-center gap-2 text-white text-sm font-medium translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
                  Åbn hjemmeside
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
                </div>
              </div>
            </div>
          </div>

          <!-- Label -->
          <div class="mt-4 px-1 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs text-white/25 tracking-widest">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="font-display text-white text-lg font-semibold">{project.title}</h3>
              <span class="text-xs text-accent bg-accent/10 border border-accent/20 rounded-full px-2.5 py-0.5 font-medium">{project.tag}</span>
            </div>
            <svg class="text-white/20 group-hover:text-accent transition-colors duration-300" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
